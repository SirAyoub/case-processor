# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=Cases
MINIO_USE_SSL=false

# Ollama Configuration
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=gemma4
# Context limit per request (number of pages)
# gemma4 handles ~32k tokens; 1 page image ≈ 800 tokens
# 30 pages safe, 50 pages max
OLLAMA_MAX_PAGES_PER_CHUNK=30

# SQL Server Configuration
DB_HOST=localhost
DB_PORT=1433
DB_NAME=CasesDB
DB_USER=sa
DB_PASSWORD=your-password

# Processing Configuration
# Temp directory for PDF pages images
TEMP_DIR=/tmp/case-processor
# Max retry attempts before marking as needs_review
MAX_RETRIES=2
# Number of concurrent cases to process
CONCURRENT_WORKERS=2
# DPI for PDF to image conversion (150=fast, 200=balanced, 300=quality)
PDF_DPI=200
